# App
PORT=3000
NODE_ENV=production

# CORS — set to your frontend URL in production (e.g. https://yourapp.up.railway.app)
# Leave unset or use * to allow all origins (not recommended in production)
CORS_ORIGIN=https://yourfrontend.example.com

# Supabase — get these from: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
